<configuration>
  <input>
    <net-file value="scenario_a.net.xml"/>
    <additional-files value="detector.xml,edge_data_config.add.xml"/>
    <route-files value="scenario_a.rou.xml"/>
  </input>
  <time><end value="15000"/></time>
  <output>
    <statistic-output value="scenario_a_stats.xml"/>
    <tripinfo-output value="tripinfo.xml"/>
  </output>
  <report><duration-log.statistics value="true"/></report>
</configuration>