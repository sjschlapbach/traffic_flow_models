<configuration>
  <input>
    <net-file value="scenario_b.net.xml"/>
    <additional-files value="detector.xml,edge_data_config.add.xml"/>
    <route-files value="scenario_b.rou.xml"/>
  </input>
  <time><end value="5000"/></time>
  <output>
    <statistic-output value="scenario_b_stats.xml"/>
  </output>
  <report><duration-log.statistics value="true"/></report>
</configuration>